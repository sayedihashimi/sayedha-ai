<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>dotnet-skills</ToolCommandName>
    <PackageId>dotnet-skills</PackageId>
    <Version>0.1.0</Version>
    <Description>Browse, install, and manage Copilot and Claude skills/plugins for .NET projects</Description>
    <Authors>sayedihashimi</Authors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Spectre.Console" Version="0.55.3-alpha.0.9" />
    <PackageReference Include="Spectre.Console.Cli" Version="0.55.1-alpha.0.4" />
    <PackageReference Include="System.CommandLine" Version="3.0.0-preview.3.26207.106" />
  </ItemGroup>

</Project>
