{
  "$schema": "http://json.schemastore.org/template",
  "author": "AUTHOR_NAME",
  "classifications": ["Solution"],
  "identity": "COMPANY.SOLUTION_NAME.CSharp",
  "name": "SOLUTION_DISPLAY_NAME",
  "shortName": "SHORT_NAME",
  "sourceName": "SOLUTION_NAME",
  "defaultName": "SOLUTION_NAME",
  "description": "SOLUTION_DESCRIPTION",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "solution",
    "editorTreatAs": "solution"
  },
  "guids": [
    "11111111-1111-1111-1111-111111111111"
  ],
  "primaryOutputs": [
    { "path": "src/PROJECT_NAME/PROJECT_NAME.csproj" }
  ],
  "symbols": {
